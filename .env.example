# Monorepo environment reference
# Copy app-specific values into:
# - apps/api/.env
# - apps/web/.env.local

# Backend
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tinyfish_ai
SQLITE_FALLBACK_URL=sqlite:///./tinyfish_ai.db
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
TINYFISH_API_KEY=your-tinyfish-api-key
TINYFISH_BASE_URL=https://api.tinyfish.ai
TINYFISH_TIMEOUT_SECONDS=45
TINYFISH_STEALTH=true
TINYFISH_USE_MOCK=true

# Frontend runtime config
# These are read server-side by apps/web /api/config and can be injected at
# runtime via Docker, AWS ECS, Google Cloud Run, Azure, or Vercel environment
# variables without rebuilding the image.
API_BASE_URL=http://localhost:8000
# apps/web also reads SUPABASE_URL and SUPABASE_ANON_KEY from the backend values above.
