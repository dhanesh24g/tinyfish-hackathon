# Base URL of the FastAPI backend. Leave unset locally to use the http://localhost:8000 fallback.
# - Vercel: set this in the project's Environment Variables UI.
# - AWS ECS / Docker: pass via `--build-arg NEXT_PUBLIC_API_BASE_URL=...` at image build time.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
